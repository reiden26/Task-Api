# =============================================================================
# Task API - Variables de Entorno
# =============================================================================

# =============================================================================
# Entorno de la Aplicación
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# =============================================================================
# Base de Datos PostgreSQL
# =============================================================================
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=taskapi_secret
POSTGRES_DB=taskdb

# =============================================================================
# Redis - Caché y Rate Limiting
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Seguridad - JWT Tokens
# =============================================================================
# IMPORTANTE: Genera una clave secreta fuerte para producción
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true

# =============================================================================
# CORS - Orígenes permitidos
# =============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# =============================================================================
# Puerto de la Aplicación
# =============================================================================
APP_PORT=8000